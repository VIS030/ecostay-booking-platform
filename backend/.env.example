# EcoStay Backend Configuration

# PostgreSQL Connection String (supports local PostgreSQL or Supabase)
# Example local: postgresql://postgres:password@localhost:5432/ecostay
# Example Supabase: postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecostay

# Razorpay Test Credentials (override with your own or use default simulated sandboxing)
RAZORPAY_KEY_ID=rzp_test_EcoStayKey123
RAZORPAY_KEY_SECRET=EcoStaySecret456789

# Port for backend
PORT=8000
